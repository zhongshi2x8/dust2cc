{
  "name": "dust2cc",
  "version": "1.1.3",
  "description": "dust2cc browser extension for CS2 skin market analysis",
  "private": true,
  "type": "module",
  "scripts": {
    "prepare:page-script": "node scripts/build-page-script.mjs",
    "predev": "npm run prepare:page-script",
    "prebuild": "npm run prepare:page-script",
    "dev": "vite",
    "build": "tsc && vite build",
    "package": "npm run build && node scripts/package-dist.mjs",
    "preview": "vite preview",
    "test": "vitest run",
    "lint": "eslint src --ext .ts,.tsx",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.0.1",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "@crxjs/vite-plugin": "^2.0.0-beta.25",
    "@types/chrome": "^0.0.268",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.19",
    "jsdom": "^26.1.0",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.5.0",
    "vite": "^5.3.0",
    "vitest": "^2.1.9"
  }
}
